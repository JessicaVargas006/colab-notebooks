bank_deposit_df.iloc[:, [0,11,14,15,16,17,18,19,20]].copy()\n","bank_deposit_dummies_df = pd.get_dummies(bank_deposit_reduced_df, columns=['poutcome'], drop_first=False)\n","bank_deposit_dummies_df.drop(['poutcome_nonexistent'], axis=1, inplace=True)\n","\n","bank_deposit_dummies_df.head()"],"id":"lYISVz4RrTWg"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/","height":178},"id":"mL0sLXWBrTWg","executionInfo":{"status":"ok","timestamp":1774353196936,"user_tz":240,"elapsed":28,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"bb570862-0e76-4e5d-851f-da1aac6c65f2"},"execution_count":3,"outputs":[{"output_type":"execute_result","data":{"text/plain":["y\n","no     3668\n","yes     451\n","Name: count, dtype: int64"],"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>count</th>\n","    </tr>\n","    <tr>\n","      <th>y</th>\n","      <th></th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>no</th>\n","      <td>3668</td>\n","    </tr>\n","    <tr>\n","      <th>yes</th>\n","      <td>451</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div><br><label><b>dtype:</b> int64</label>"]},"metadata":{},"execution_count":3}],"source":["# Define predictors and outcome\n","# Outcome column y is the 8th column per instructions\n","y = bank_deposit_dummies_df['y']\n","X = bank_deposit_dummies_df.drop(columns=['y'])\n","\n","# Check outcome levels\n","y.value_counts()"],"id":"mL0sLXWBrTWg"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dVI8NhsprTWg","executionInfo":{"status":"ok","timestamp":1774353198754,"user_tz":240,"elapsed":16,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"9267091b-b94f-459f-ec8f-66c8752c15b6"},"execution_count":4,"outputs":[{"output_type":"execute_result","data":{"text/plain":["((3295, 9), (824, 9))"]},"metadata":{},"execution_count":4}],"source":["# Train/test split (80/20), class standard random_state=1\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X, y, test_size=0.20, random_state=1, stratify=y\n",")\n","X_train.shape, X_test.shape"],"id":"dVI8NhsprTWg"},{"cell_type":"markdown","metadata":{"id":"urZpVrWZrTWg"},"source":["### 2a) Logistic Regression (no tuning), only class_weight='balanced'\n","Report **Sensitivity** and **Specificity** on test data.\n","- Sensitivity = Recall for the positive class ('yes')\n","- Specificity = Recall for the negative class ('no')\n"],"id":"urZpVrWZrTWg"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"nXhlQtccrTWh","executionInfo":{"status":"ok","timestamp":1774353203561,"user_tz":240,"elapsed":623,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"bd4fc345-1e70-4162-c6d7-6580e89cd8d0"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Confusion matrix (rows=actual [no,yes], cols=pred [no,yes]):\n"," [[582 152]\n"," [ 31  59]]\n","Sensitivity (Recall for yes): 0.6555555555555556\n","Specificity (Recall for no): 0.7929155313351499\n","\n","Classification report:\n","              precision    recall  f1-score   support\n","\n","          no       0.95      0.79      0.86       734\n","         yes       0.28      0.66      0.39        90\n","\n","    accuracy                           0.78       824\n","   macro avg       0.61      0.72      0.63       824\n","weighted avg       0.88      0.78      0.81       824\n","\n"]}],"source":["# 2a: Logistic Regression (no tuning)\n","logreg_2a = LogisticRegression(class_weight='balanced', max_iter=10000)\n","logreg_2a.fit(X_train, y_train)\n","y_pred_2a = logreg_2a.predict(X_test)\n","\n","cm_2a = confusion_matrix(y_test, y_pred_2a, labels=['no','yes'])\n","TN, FP, FN, TP = cm_2a.ravel()\n","\n","sensitivity_2a = TP / (TP + FN)   # recall for 'yes'\n","specificity_2a = TN / (TN + FP)   # recall for 'no'\n","\n","print('Confusion matrix (rows=actual [no,yes], cols=pred [no,yes]):\\n', cm_2a)\n","print('Sensitivity (Recall for yes):', sensitivity_2a)\n","print('Specificity (Recall for no):', specificity_2a)\n","print('\\nClassification report:')\n","print(classification_report(y_test, y_pred_2a))"],"id":"nXhlQtccrTWh"},{"cell_type":"markdown","source":["**Answer 2a:**  \n","On the test set, Sensitivity (Recall for **yes**) = **0.6556**,  \n","and Specificity (Recall for **no**) = **0.7929**."],"metadata":{"id":"OW-JcwWHwffy"},"id":"OW-JcwWHwffy"},{"cell_type":"markdown","metadata":{"id":"CFS9TifurTWh"},"source":["### 2b) Logistic Regression with GridSearchCV (MUST follow class method)\n","- Use **recall for the positive class ('yes')** as the selection metric.\n","- Then evaluate on the **test set** and compare sensitivity & specificity vs 2a.\n"],"id":"CFS9TifurTWh"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"L0Egn2isrTWh","executionInfo":{"status":"ok","timestamp":1774353542898,"user_tz":240,"elapsed":334200,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"6fe8dfb1-7b6b-4cbc-e640-9e7a843e5a25"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Best hyperparameters: {'C': 0.01, 'penalty': 'l1', 'solver': 'liblinear'}\n","Best CV recall (yes): 0.7005894213650307\n"]}],"source":["# 2b: GridSearchCV (class-style)\n","# CV object (classification class method often uses 3 folds for computation)\n","cv_object = KFold(n_splits=3, shuffle=True, random_state=1)\n","\n","# Custom recall scorer for positive class 'yes'\n","recall_yes_scorer = make_scorer(recall_score, pos_label='yes')\n","\n","# Model base\n","logreg_base = LogisticRegression(class_weight='balanced', max_iter=10000)\n","\n","# Hyperparameter grid (C = inverse regularization strength; penalty)\n","hyperparam_grid = {\n","    'solver': ['liblinear'],\n","    'penalty': ['l1', 'l2'],\n","    'C': [0.01, 0.1, 1, 10, 100]\n","}\n","\n","grid_search_2b = GridSearchCV(\n","    estimator=logreg_base,\n","    param_grid=hyperparam_grid,\n","    cv=cv_object,\n","    scoring=recall_yes_scorer,\n","    n_jobs=-1\n",")\n","\n","grid_search_2b.fit(X_train, y_train)\n","\n","print('Best hyperparameters:', grid_search_2b.best_params_)\n","print('Best CV recall (yes):', grid_search_2b.best_score_)"],"id":"L0Egn2isrTWh"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_KaDp2uQrTWh","executionInfo":{"status":"ok","timestamp":1774353566493,"user_tz":240,"elapsed":22,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"08ef1a64-f4db-4505-aa61-88e2dfa4ad8d"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["Confusion matrix (rows=actual [no,yes], cols=pred [no,yes]):\n"," [[543 191]\n"," [ 28  62]]\n","Sensitivity (Recall for yes): 0.6888888888888889\n","Specificity (Recall for no): 0.7397820163487738\n","\n","Classification report:\n","              precision    recall  f1-score   support\n","\n","          no       0.95      0.74      0.83       734\n","         yes       0.25      0.69      0.36        90\n","\n","    accuracy                           0.73       824\n","   macro avg       0.60      0.71      0.60       824\n","weighted avg       0.87      0.73      0.78       824\n","\n"]}],"source":["# 2b: Evaluate tuned model on test set\n","best_logreg = grid_search_2b.best_estimator_\n","y_pred_2b = best_logreg.predict(X_test)\n","\n","cm_2b = confusion_matrix(y_test, y_pred_2b, labels=['no','yes'])\n","TNb, FPb, FNb, TPb = cm_2b.ravel()\n","\n","sensitivity_2b = TPb / (TPb + FNb)\n","specificity_2b = TNb / (TNb + FPb)\n","\n","print('Confusion matrix (rows=actual [no,yes], cols=pred [no,yes]):\\n', cm_2b)\n","print('Sensitivity (Recall for yes):', sensitivity_2b)\n","print('Specificity (Recall for no):', specificity_2b)\n","\n","print('\\nClassification report:')\n","print(classification_report(y_test, y_pred_2b))"],"id":"_KaDp2uQrTWh"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"LAJgW3d2rTWh","executionInfo":{"status":"ok","timestamp":1774353570489,"user_tz":240,"elapsed":23,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"8ab26c9d-104d-498a-bc82-21f0986f4bcc"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Baseline (2a) sensitivity: 0.6555555555555556\n","Baseline (2a) specificity: 0.7929155313351499\n","Tuned (2b) sensitivity: 0.6888888888888889\n","Tuned (2b) specificity: 0.7397820163487738\n","\n","Conclusion: NO — tuned model does not improve BOTH sensitivity and specificity.\n"]}],"source":["# 2b: Comparison statement (does tuned model improve BOTH sensitivity and specificity?)\n","print('Baseline (2a) sensitivity:', sensitivity_2a)\n","print('Baseline (2a) specificity:', specificity_2a)\n","print('Tuned (2b) sensitivity:', sensitivity_2b)\n","print('Tuned (2b) specificity:', specificity_2b)\n","\n","both_better = (sensitivity_2b > sensitivity_2a) and (specificity_2b > specificity_2a)\n","if both_better:\n","    print('\\nConclusion: YES — tuned model improves BOTH sensitivity and specificity.')\n","else:\n","    print('\\nConclusion: NO — tuned model does not improve BOTH sensitivity and specificity.')"],"id":"LAJgW3d2rTWh"},{"cell_type":"markdown","source":["**Answer 2b (Justification):**  \n","We tuned hyperparameters using **recall for the positive class (yes)** on the training data (GridSearchCV).\n","\n","On the test set:  \n","- Baseline model -> Sensitivity = **0.6556**, Specificity = **0.7929**  \