er=10000, multi_class='auto'))\n","])\n","\n","pipe.fit(X_train_w, y_train_w)\n","y_pred_w = pipe.predict(X_test_w)\n","\n","print('Classification report:\\n')\n","print(classification_report(y_test_w, y_pred_w, target_names=['Wine 1 (class_0)','Wine 2 (class_1)','Wine 3 (class_2)']))"],"id":"UmFcRBgarTWi"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"NJawXUlorTWi","executionInfo":{"status":"ok","timestamp":1774353584696,"user_tz":240,"elapsed":12,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"89a4343c-1aed-4717-906d-b15757901e6a"},"execution_count":14,"outputs":[{"output_type":"stream","name":"stdout","text":["Confusion Matrix (rows=actual, cols=pred):\n"," [[11  0  1]\n"," [ 3 10  1]\n"," [ 2  3  5]]\n"]}],"source":["# Confusion matrix\n","cm_w = confusion_matrix(y_test_w, y_pred_w, labels=[0,1,2])\n","print('Confusion Matrix (rows=actual, cols=pred):\\n', cm_w)"],"id":"NJawXUlorTWi"},{"cell_type":"markdown","metadata":{"id":"KCSFKVPbrTWi"},"source":["### 3a) Most often misclassified class\n","Interpret using the **classification report**.\n","A class is \"most often misclassified\" when it has the **lowest recall** (many false negatives), meaning the model misses that class most often.\n"],"id":"KCSFKVPbrTWi"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"wve3gn5QrTWi","executionInfo":{"status":"ok","timestamp":1774353587172,"user_tz":240,"elapsed":34,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"63e6adaf-b2e7-4683-c561-9ab93309ef07"},"execution_count":15,"outputs":[{"output_type":"stream","name":"stdout","text":["Recall by class: {0: 0.9166666666666666, 1: 0.7142857142857143, 2: 0.5}\n","Most often misclassified class (lowest recall): 2\n"]}],"source":["# 3a: Identify the class with lowest recall\n","report = classification_report(y_test_w, y_pred_w, output_dict=True)\n","recalls = {0: report['0']['recall'], 