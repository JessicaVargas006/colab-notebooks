 col 3 (1-indexed) => [0,2] in Python\n","row1_col3_value = cm_w[0,2]\n","print('Confusion matrix entry (row 1, col 3) = cm[0,2] =', row1_col3_value)"],"id":"ZONM2I9IrTWj"},{"cell_type":"markdown","metadata":{"id":"3wRxus28rTWj"},"source":["### 3d) Manual computations from the classification report\n","#### 3d1) Show how recall for class 0 is obtained\n","Recall(class 0) = TP0 / (TP0 + FN0)\n","\n","#### 3d2) Show how f1-score for class 2 is obtained\n","F1(class 2) = 2 * (precision2 * recall2) / (precision2 + recall2)\n"],"id":"3wRxus28rTWj"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"TKpCF7ywrTWj","executionInfo":{"status":"ok","timestamp":1774353593460,"user_tz":240,"elapsed":15,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"11838892-59c9-4d3d-a63b-673a492d8fb2"},"execution_count":18,"outputs":[{"output_type":"stream","name":"stdout","text":["TP0 = 11\n","FN0 = 1\n","Recall(class 0) = TP0 / (TP0 + FN0) = 0.9166666666666666\n","Recall(class 0) from report = 0.9166666666666666\n"]}],"source":["# 3d1: Compute recall for class 0 from confusion matrix\n","# For class 0: TP0 is cm[0,0]; FN0 is sum of row 0 excluding TP\n","TP0 = cm_w[0,0]\n","FN0 = cm_w[0,1] + cm_w[0,2]\n","recall0_manual = TP0 / (TP0 + FN0) if (TP0 + FN0) > 0 else np.nan\n","\n","print('TP0 =', TP0)\n","print('FN0 =', FN0)\n","print('Recall(class 0) = TP0 / (TP0 + FN0) =', recall0_manual)\n","print('Recall(class 0) from report =', report['0']['recall'])"],"id":"TKpCF7ywrTWj"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"SSWEUXyNrTWj","executionInfo":{"status":"ok","timestamp":1774353595456,"user_tz":240,"elapsed":13,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"1db6c0ac-107e-438d-c192-036845852e98"},"execution_count":19,"outputs":[{"output_type":"stream","name":"stdout","text":["Precision(class 2) = 0.7142857142857143\n","Recall(class 2) = 0.5\n","F1(class 2) manual = 0.588235294117647\n","F1(class 2) from report = 0.5882352941176471\n"]}],"source":["# 3d2: Compute f1-score for class 2 using precision and recall\n","precision2 = report['2']['precision']\n","recall2 = report['2']['recall']\n","f1_2_manual = 2 * (precision2 * recall2) / (precision2 + recall2) if (precision2 + recall2) > 0 else np.nan\n","\n","print('Precision(class 2) =', precision2)\n","print('Recall(class 2) =', recall2)\n","print('F1(class 2) manual =', f1_2_manual)\n","print('F1(class 2) from report =', report['2']['f1-score'])"],"id":"SSWEUXyNrTWj"},{"cell_type":"markdown","metadata":{"id":"mOW4nJ0QrTWj"},"source":["### 3e) Challenge: Write the logistic regression equations for the 3 classes\n","Because we standardized predictors, the equations are written in terms of standardized predictors:\n","- Let z1 = standardized(x1), z2 = standardized(x2).\n","\n","The multinomial logistic regression uses 3 linear scores:\n","- score_k = b0_k + b1_k*z1 + b2_k*z2\n","\n","Then probabilities use softmax:\n","- P(class=k) = exp(score_k) / sum_j exp(score_j)\n","\n","The cell below prints intercepts and coefficients used to write the equations.\n"],"id":"mOW4nJ0QrTWj"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ynp_59NxrTWk","executionInfo":{"status":"ok","timestamp":1774353597920,"user_tz":240,"elapsed":16,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"b6bd9566-db5f-410d-ad44-b89338469388"},"execution_count":20,"outputs":[{"output_type":"stream","name":"stdout","text":["Intercepts (b0) for classes 0,1,2:\n","[-0.23021258  0.08467495  0.14553763]\n","\n","Coefficients (rows=classes 0,1,2; cols=standardized predictors z1,z2):\n","[[ 1.84057728 -0.59071564]\n"," [-2.02285289 -0.37542288]\n"," [ 0.18227561  0.96613852]]\n"]}],"source":["# 3e: Extract coefficients from the fitted logistic regression in the pipeline\n","logreg_model = pipe.named_steps['logreg']\n","\n","print('Intercepts (b0) for classes 0,1,2:')\n","print(logreg_model.intercept_)\n","\n","print('\\nCoefficients (rows=classes 0,1,2; cols=standardized predictors z1,z2):')\n","print(logreg_model.coef_)"],"id":"ynp_59NxrTWk"},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Jg6lKYcorTWk","executionInfo":{"status":"ok","timestamp":1774353600552,"user_tz":240,"elapsed":28,"user":{"displayName":"Jessica Vargas","userId":"04622878135586132667"}},"outputId":"c91a0255-d741-42f8-9f77-7ddae5b21421"},"execution_count":21,"outputs":[{"output_type":"stream","name":"stdout","text":["Class 0: score_0 = -0.230213 +1.840577*z1 -0.590716*z2\n","Class 1: score_1 = +0.084675 -2.022853*z1 -0.375423*z2\n","Class 2: score_2 = +0.145538 +0.182276*z1 +0.966139*z2\n","\n","Probabilities: P(class=k) = exp(score_k) / (exp(score_0)+exp(score_1)+exp(score_2))\n"]}],"source":["# Pretty-print equations\n","b0 = logreg_model.intercept_\n","B = logreg_model.coef_\n","\n","for k in [0,1,2]:\n","    print(f'Class {k}: score_{k} = {b0[k]:+.6f} {B[k,0]:+.6f}*z1 {B[k,1]:+.6f}*z2')\n","\n","print('\\nProbabilities: P(class=k) = exp(score_k) / (exp(score_0)+exp(score_1)+exp(score_2))')"],"id":"Jg6lKYcorTWk"}],"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.x"},"colab":{"provenance":[]}},"nbformat":4,"nbformat_minor":5}